{
  "name": "@adametherzlab/growlog",
  "version": "0.1.0",
  "description": "CLI plant growth logger with watering, fertilizer, and environmental tracking",
  "type": "module",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "bun test",
    "build": "bun build src/index.ts --outdir dist",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "bun-types": "latest",
    "typescript": "^5.5.0"
  },
  "keywords": [
    "typescript",
    "bun",
    "typescript",
    "bun",
    "cli",
    "gardening",
    "logging",
    "greenhouse"
  ],
  "author": "AdametherzLab",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AdametherzLab/growlog.git"
  },
  "homepage": "https://github.com/AdametherzLab/growlog#readme",
  "bugs": {
    "url": "https://github.com/AdametherzLab/growlog/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false
}